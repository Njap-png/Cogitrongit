# PHANTOM Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# LLM BACKENDS - Set your API keys
# ============================================================================

# OpenAI (GPT-4o, GPT-4-turbo, GPT-3.5-turbo)
# OPENAI_API_KEY=sk-your-key-here

# Anthropic (Claude 3.5 Sonnet, Claude 3 Haiku)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Groq (Free tier, llama-3.1-70b, mixtral)
# GROQ_API_KEY=gsk_your-key-here

# OpenRouter (100+ models with single key)
# OPENROUTER_API_KEY=sk-or-your-key-here

# Google Gemini
# GOOGLE_API_KEY=your-key-here

# ============================================================================
# OPTIONAL SERVICES
# ============================================================================

# Shodan for host/device search
# SHODAN_API_KEY=your-key-here

# GitHub for code/repo search (higher rate limits)
# GITHUB_TOKEN=ghp_your-token-here

# Google Custom Search Engine
# GOOGLE_CSE_KEY=your-key-here
# GOOGLE_CSE_ID=your-id-here

# SearXNG (self-hosted privacy search)
# SEARXNG_URL=http://localhost:8888

# ============================================================================
# CONFIGURATION
# ============================================================================

# UI Theme: matrix | dracula | monokai | blood
# PHANTOM_THEME=matrix

# Thinking mode: fast | deep | paranoid
# PHANTOM_THINKING_MODE=deep

# Enable auto-evolution on startup
# PHANTOM_EVOLVE_ON_STARTUP=false

# ============================================================================
# DEBUG
# ============================================================================

# Enable verbose logging
# PHANTOM_DEBUG=false

# Log file location
# PHANTOM_LOG_FILE=~/.phantom/logs/phantom.log